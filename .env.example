# OpenClaw VPS environment.
# bootstrap.sh fills the __REPLACE_*__ placeholders on first run.
# Anything you add by hand survives re-runs.

# Gateway image. Pin a version for stability; bump in PRs.
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:2026.4.26

# Gateway auth token (generated by bootstrap).
OPENCLAW_GATEWAY_TOKEN=__REPLACE_TOKEN__

# Network bind. 'lan' = listen on all interfaces (UFW + Tailscale gate access).
# 'localhost' = strictly loopback (use only for SSH-tunnelled access).
OPENCLAW_GATEWAY_BIND=lan

# Ports (host:container).
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790

# Persistent state on host (mounted into the container).
OPENCLAW_CONFIG_DIR=__REPLACE_CONFIG_DIR__
OPENCLAW_WORKSPACE_DIR=__REPLACE_WORKSPACE_DIR__

# Timezone for cron + logs.
OPENCLAW_TZ=UTC

# LLM provider — set on the VPS via ./scripts/set-anthropic-key.sh
# (do NOT commit a real key here).
ANTHROPIC_API_KEY=

# Telegram bot — set on the VPS via ./scripts/onboard-telegram.sh
TELEGRAM_BOT_TOKEN=
